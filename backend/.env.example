# Meta WhatsApp Cloud API Credentials (from Meta App Dashboard / WhatsApp Manager)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxx
WHATSAPP_WABA_ID=xxxxxxxxxxxxxxx
GRAPH_API_VERSION=v25.0

# API Key for authenticating requests from StockAlert app
# Generate a random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here

# Upstash Redis (rate limiting) - auto-injected by the Vercel Upstash
# marketplace integration once a database is linked to this project.
# Vercel uses the legacy "Vercel KV" naming (KV_REST_API_URL/TOKEN), not
# the raw Upstash naming - code checks both, preferring KV_REST_API_*.
# If unset, rate limiting fails open (no limiting applied).
KV_REST_API_URL=https://xxxxxxxxxxxxxxxxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rate limit overrides (optional - defaults shown)
# RATE_LIMIT_PER_NUMBER_PER_MINUTE=10
# RATE_LIMIT_PER_NUMBER_PER_HOUR=60
# RATE_LIMIT_GLOBAL_PER_MINUTE=100
# RATE_LIMIT_GLOBAL_PER_HOUR=2000
